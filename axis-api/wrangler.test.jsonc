{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "axis-api-mainnet",
	"main": "src/app.ts",
	"compatibility_date": "2024-09-09",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"d1_databases": [
		{
			"binding": "axis_main_db",
			"database_name": "axis-main-db",
			"database_id": "9fac1183-a477-4840-b3cb-a4a4c0ba1969",
			"migrations_dir": "./migrations/main"
		},
		{
			"binding": "axis_price_db",
			"database_name": "axis-price-db",
			"database_id": "df2a5068-b099-4d2d-ab9b-885281f16fc9",
			"migrations_dir": "./migrations/price"
		},
		{
			"binding": "whitelist_db",
			"database_name": "axis-wlv2",
			"database_id": "ae62cf10-e8b1-4cfb-8823-91da78d51220"
		},
		{
			"binding": "DB_INVITE",
			"database_name": "axis-invites",
			"database_id": "a01dd752-2536-4802-8cfb-1eb6c0902952"
		}
	],
	"send_email": [
		{
			"name": "EMAIL"
		}
	],
	"r2_buckets": [
		{
			"binding": "IMAGES",
			"bucket_name": "axis-images",
			"preview_bucket_name": "axis-images-preview"
		}
	]
}
